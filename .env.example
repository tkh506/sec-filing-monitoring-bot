# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# OpenRouter API key, for on-demand "Summarize with AI" button
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# OpenRouter model to use for summarization
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# SEC EDGAR requires a descriptive User-Agent with a real name + email, e.g. "Jane Doe jane@example.com"
SEC_EDGAR_USER_AGENT=YOUR_NAME_HERE YOUR_EMAIL_HERE

# Path to the SQLite database file
DATABASE_PATH=data/bot.db
